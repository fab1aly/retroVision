<style>
    video-webtorrent {
        #hero {
            height: 100%;

            video {
                width: 100%;
            }
        }

        #progressBar {
            height: 5px;
            width: 0%;
            background-color: #35b44f;
            transition: width .4s ease-in-out;
        }

        #hero.is-seed .show-seed {
            display: inline;
        }

        #hero.is-seed .show-leech {
            display: none;
        }

        .show-seed {
            display: none;
        }

        #status code {
            font-size: 90%;
            font-weight: 700;
            margin-left: 3px;
            margin-right: 3px;
            border-bottom: 1px dashed rgba(255, 255, 255, 0.3);
        }

        #hero.is-seed {
            background-color: #154820;
            transition: .5s .5s background-color ease-in-out;
        }

        #hero {
            background-color: #2a3749;
        }

        #status {
            color: #fff;
            font-size: 17px;
            padding: 5px;
        }

        a:link,
        a:visited {
            color: #30a247;
            text-decoration: none;
        }
    }
</style>
<article>
    <header>
        <h2><?= $film_data['film_name'] ?></h2>
    </header>

    <main>
        <video-webtorrent
            hash=<?= $film_data['torrent_hash'] ?>
            filename=<?= $film_data['torrent_filename'] ?>>
        </video-webtorrent>
    </main>

    <footer>
        <h3>Informations</h3>
        <p x-data='<?= str_replace("'", "", $film_data['film_json']) ?>'>
            <strong>Title :</strong> <span x-text="Title"></span><br />
            <strong>Director :</strong> <span x-text="Director"></span><br />
            <strong>Actors :</strong> <span x-text="Actors"></span><br />
            <strong>Year :</strong> <span x-text="Year"></span><br />
            <strong>Genre :</strong> <span x-text="Genre"></span><br />
            <strong>Runtime :</strong> <span x-text="Runtime"></span><br />
            <strong>Language :</strong> <span x-text="Language"></span><br />
            <strong>Plot :</strong> <em x-text="Plot"></em><br />
        </p>

    </footer>
</article>


<!-- video-webtorrent.js -->
<template id="video-webtorrent">
    <div id="hero">
        <div id="output">
            <div id="progressBar"></div>
            <!-- The video player will be added here -->
            <video id="video" controls></video>
        </div>
        <!-- Statistics -->
        <div id="status">
            <div>
                <span class="show-leech">Downloading </span>
                <span class="show-seed">Seeding </span>
                <code>
                    <!-- Informative link to the torrent file -->
                    <a id="torrentLink" href="https://webtorrent.io/torrents/sintel.torrent">sintel.torrent</a>
                </code>
                <span class="show-leech"> from </span>
                <span class="show-seed"> to </span>
                <code id="numPeers">0 peers</code>.
            </div>
            <div>
                <code id="downloaded"></code>
                of <code id="total"></code>
                — <span id="remaining"></span><br />
                &#x2198;<code id="downloadSpeed">0 b/s</code>
                / &#x2197;<code id="uploadSpeed">0 b/s</code>
            </div>
        </div>
    </div>
</template>
<!-- Moment is used to show a human-readable remaining time -->
<script defer src="https://momentjs.com/downloads/moment.min.js"></script>


<script type="module" defer>
    // import 'https://cdn.jsdelivr.net/npm/webtorrent@latest/webtorrent.min.js'
    // import WebTorrent from "https://esm.sh/webtorrent";
    import WebTorrent from './webtorrent.min.js'

    if (!customElements.get("video-webtorrent")) {
        customElements.define("video-webtorrent", class VideoWebTorrent extends HTMLElement {
            constructor() {
                super();
                this.appendChild(document.querySelector('template#video-webtorrent').content.cloneNode(true))
            }

            connectedCallback() {

                // HTML elements
                const $hero = this.querySelector('#hero')
                const $progressBar = this.querySelector('#progressBar')
                const $numPeers = this.querySelector('#numPeers')
                const $downloaded = this.querySelector('#downloaded')
                const $total = this.querySelector('#total')
                const $remaining = this.querySelector('#remaining')
                const $uploadSpeed = this.querySelector('#uploadSpeed')
                const $downloadSpeed = this.querySelector('#downloadSpeed')

                // Magnet URI with trackers
                const magnet = `magnet:?xt=urn:btih:` + this.getAttribute('hash')
                const trackers = ['wss://tracker.openwebtorrent.com', 'wss://tracker.btorrent.xyz']
                // const trackers = '&tr=wss%3A%2F%2Ftracker.openwebtorrent.com&tr=wss%3A%2F%2Ftracker.btorrent.xyz&tr=wss%3A%2F%2Ftracker.webtorrent.dev'
                const torrentId = magnet + trackers.map(tracker => `&tr=${encodeURIComponent(tracker)}`).join('')

                // File name to download
                const file_name = this.getAttribute('filename')

                // WebTorrent client
                const client = window.client = new WebTorrent({
                    // torrentPort: 9000,
                    dht: true,
                })

                // Service Worker registration
                if ('serviceWorker' in navigator) {
                    navigator.serviceWorker.register('./sw.min.js', {
                        scope: './'
                    }).then(reg => {
                        const worker = reg.active || reg.waiting || reg.installing

                        function checkState(worker) {
                            return worker.state === 'activated' && client.createServer({
                                controller: reg
                            }) && download()
                        }
                        if (!checkState(worker)) {
                            worker.addEventListener('statechange', ({
                                target
                            }) => checkState(target))
                        }
                    }).catch(error => {
                        console.error('Service Worker registration failed:', error);
                        // Fallback: télécharger directement sans Service Worker
                        download();
                    });
                } else {
                    console.warn('Service Workers are not supported in this browser. WebTorrent might not work properly.');
                    // Essayer de télécharger directement sans Service Worker
                    download();
                }


                function download() {
                    // Client alert in console
                    client.on('add', function(torrent) {
                        // console.log('client.on(add... called!')

                        // Torrent alert in console
                        torrent.on('infoHash', function() {
                            console.log('torrent infoHash: ' + torrent.infoHash)
                        })
                        torrent.on('metadata', function() {
                            console.log('torrent metadata: ' + torrent.metadata.slice(0, 11) + ',...')
                        })
                        torrent.on('ready', function() {
                            console.log('torrent ready: ' + torrent.name)
                        })
                        torrent.on('warning', function(err) {
                            console.log('torrent warning: ' + err)
                        })
                        torrent.on('error', function(err) {
                            console.log('torrent error: ' + err)
                        })
                        torrent.on('noPeers', function(announceType) {
                            // console.log('torrent noPeers: ' + announceType)
                        })
                    })
                    client.on('error', function(err) {
                        console.log('client error: ' + err)
                    })

                    // Download the torrent
                    client.add(torrentId, function(torrent) {
                        // console.log('client.add(torrent... called!')

                        // Deselect all files on initial download                                                   //////////////
                        torrent.files.forEach(file => file.deselect()); // auto stop all dl
                        // torrent.deselect(0, torrent.pieces.length - 1, false); /////////////

                        // Torrents can contain many files. Let's use the .mp4 file
                        const file = torrent.files.find(function(file) {
                            return file.name.endsWith(file_name) /// filename
                        })

                        // Select file with provided index                                               ///////////////////////
                        if (file) torrent.select(file._startPiece, file._endPiece, false); // dl one file

                        // Stream the file in the browser
                        const video = document.querySelector('video#video')
                        // video.src = file.streamURL
                        file.streamTo(video);
                        // console.log(file)
                        // console.log('Ready to play!')
                        // video.autoplay = "true"


                        // Trigger statistics refresh
                        file.on('done', onDone)
                        setInterval(onProgress, 500)
                        onProgress()


                        // Statistics
                        function onProgress() {
                            // Peers
                            $numPeers.innerHTML = torrent.numPeers + (torrent.numPeers === 1 ? ' peer' : ' peers')

                            // Progress
                            const percent = Math.round(file.progress * 100 * 100) / 100 ////
                            $progressBar.style.width = percent + '%'
                            $downloaded.innerHTML = prettyBytes(file.downloaded) ///// 
                            $total.innerHTML = prettyBytes(file.length) /////

                            // Remaining time
                            let remaining
                            if (torrent.done) { ////
                                remaining = 'Done.'
                            } else {
                                remaining = moment.duration(torrent.timeRemaining / 1000, 'seconds').humanize() /////
                                remaining = remaining[0].toUpperCase() + remaining.substring(1) + ' remaining.'
                            }
                            $remaining.innerHTML = remaining

                            // Speed rates
                            $downloadSpeed.innerHTML = prettyBytes(torrent.downloadSpeed) + '/s' ///////
                            $uploadSpeed.innerHTML = prettyBytes(torrent.uploadSpeed) + '/s' ////
                        }

                        // On torrent done alert (green background)
                        function onDone() {
                            $hero.classList.add('is-seed')
                            onProgress()
                        }
                    })

                    // Human readable bytes util
                    function prettyBytes(num) {
                        const units = ['B', 'kB', 'MB', 'GB', 'TB', 'PB', 'EB', 'ZB', 'YB']
                        const neg = num < 0
                        if (neg) num = -num
                        if (num < 1) return (neg ? '-' : '') + num + ' B'
                        const exponent = Math.min(Math.floor(Math.log(num) / Math.log(1000)), units.length - 1)
                        const unit = units[exponent]
                        num = Number((num / Math.pow(1000, exponent)).toFixed(2))
                        return (neg ? '-' : '') + num + ' ' + unit
                    }
                }
            }

            disconnectedCallback() {
                if (client.torrents) {
                    client.torrents.forEach(torrent => {
                        torrent.destroy()
                    })
                }

                if (client._server) {
                    client._server.close()
                }
                if (client) {
                    client.destroy()
                }
            }
        });
    }
</script>
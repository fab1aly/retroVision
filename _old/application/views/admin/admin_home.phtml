					<?php endforeach; ?>
				</tbody>
				<tfoot>
					<tr>
						<th scope="row">Total</th>
						<td></td>
						<td><?= count($film_array) ?></td>
					</tr>
				</tfoot>
			</table>
		</main>
		<footer>
			<details role="button" class="secondary">
				<summary>
					<span class="pico-color-pumpkin-100">Add Film</span>
				</summary>
				<form>
					<fieldset role="group">
						<input id="slug"
							type="text" name="slug" placeholder="Slug"
							oninput="if (this.value.length>=3) { getOMDbData(); };">
						<input id="year"
							type="number" name="year" placeholder="Year"
							maxlength="4" style="flex-basis: 6.5em;"
							alt="Helping search on OMDb API"
							data-tooltip="Helping search on OMDb API">
					</fieldset>

					<input id="imdbID"
						type="text" name="imdbID"
						placeholder="ImdbID">
					<textarea id="json"
						type="text" name="json"
						placeholder="JSON"
						rows="4" readonly></textarea>
					<textarea id="plot"
						type="text" name="plot"
						placeholder="Plot"
						rows="5" readonly></textarea>

					<button type="submit">
						<span class="pico-color-pumpkin-200">Add</span>
					</button>
				</form>
				<script>
					async function getOMDbData() {
						slug = document.querySelector('form #slug').value;
						year = document.querySelector('form #year').value;
						data = await fetch(`https://www.omdbapi.com/?apikey=<?= $OMDbAPIKey ?>&t=${slug}&y=${year}`).then(response => response.json());
						plot = await fetch(`https://www.omdbapi.com/?apikey=<?= $OMDbAPIKey ?>&t=${slug}&y=${year}&plot=full`).then(response => response.json()).then(data => data.Plot);
						setOMDbData();
					}

					function setOMDbData() {
						document.querySelector('form #imdbID').value = data.imdbID;
						document.querySelector('form #json').value = JSON.stringify(data);
						document.querySelector('form #plot').value = plot;
					}
				</script>
			</details>
		</footer>
	</article>
</section>

<section id="film_view">
	<article class="overflow-auto">
		<header>
			<h2 class="pico-color-pumpkin-300">All Films</h2>
		</header>
		<main class="overflow-auto">
			<table class="striped">
				<thead>
					<tr>
						<th scope="col">Slug</th>
						<th scope="col">ImdbID</th>
						<th scope="col">Date of registration</th>
					</tr>
				</thead>
				<tbody>
					<?php foreach ($film_array as $film) : ?>
						<tr>
							<td><?= $film['slug'] ?></td>

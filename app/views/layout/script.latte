    function closeDialogJS() {
        dialog = document.querySelector("dialog[open]")
        if (dialog) {
            dialog.close()
        };
    }

    function openDialog() {
        $refs.dialog.showModal();
    }

    function closeDialog() {
        this.$refs.dialog.close();
    }


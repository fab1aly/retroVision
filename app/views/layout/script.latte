    function hideStatusToForm(form) {
        const FORM = document.querySelector('#' + form);
        const STATUS = document.querySelector('#user_response_status');
        if (FORM) {
            FORM.hidden = true;
        }
        setTimeout(() => {
            if (STATUS) {
                STATUS.hidden = true;
            }
            if (FORM) {
                FORM.hidden = false;
            }
        }, 750);
    }

    function signInForm(status) {
        switch (status) {
            case "success":
                console.log("signInForm success")
                hideStatusToForm('user_form')
                setTimeout(() => {
                    closeDialogJS();
                }, 500);
                break;

            case "error":
                hideStatusToForm('user_form');
                break;
        }
    }

    function signUpForm(status) {
        switch (status) {
            case "success":
                hideStatusToForm('user_form');
                break;

            case "error":
                hideStatusToForm('user_form');
                break;
        }
    }

    function signForgetForm(status) {
        switch (status) {
            case "success":
                hideStatusToForm('user_form');
                break;

            case "error":
                hideStatusToForm('user_form');
                break;
        }
    }

    function userProfileForm(status) {
        switch (status) {
            case "success":
                hideStatusToForm('user_form');
                break;

            case "error":
                hideStatusToForm('user_form');
                break;
        }
    }

    function userDelete(status) {
        switch (status) {
            case "success":
                setTimeout(() => {
                    closeDialog('user_dialog');
                }, 500);
                break;

            case "error":
                hideStatusToForm('user_form');
                break;
        }
    }
</script>